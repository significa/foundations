{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "extends": ["@significa/biome-config"],
  "files": {
    "includes": ["!!**/dist", "!!**/.astro", "!!**/*.astro"]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "linter": {
    "rules": {
      "correctness": {
        "noUnknownProperty": {
          "level": "error",
          "options": {
            "ignore": ["corner-shape"]
          }
        }
      },
      "suspicious": {
        "noArrayIndexKey": {
          "level": "off"
        }
      },
      "nursery": {
        "useSortedClasses": {
          "level": "warn",
          "fix": "safe",
          "options": {
            "attributes": ["classList"],
            "functions": ["clsx", "cva", "tw", "tw.*"]
          }
        }
      },
      "a11y": {
        "useMediaCaption": "off",
        "noLabelWithoutControl": "off"
      }
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 128,
      "lineEnding": "lf",
      "quoteStyle": "double"
    },
    "linter": {
      "enabled": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.astro"],
      "linter": {
        "rules": {
          "correctness": {
            "useExhaustiveDependencies": "off",
            "useHookAtTopLevel": "off",
            "noUnusedImports": "off",
            "noUnusedVariables": "off"
          },
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    }
  ]
}
