{
  "name": "foundations",
  "type": "module",
  "version": "0.0.1-development",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "astro dev",
    "dev:pagefind": "pnpm build && node ./scripts/pagefind.mjs --dev && pnpm dev",
    "build": "astro build",
    "postbuild": "node scripts/pagefind.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "types:check": "astro sync && tsc -noEmit",
    "format": "biome format --write . && prettier --list-different --write \"**/*.astro\"",
    "lint": "biome lint --write --unsafe .",
    "check:deps": "node scripts/check-page-deps.mjs",
    "knip": "knip",
    "check": "biome ci && prettier --check  \"**/*.astro\" && pnpm types:check && pnpm check:deps && pnpm knip"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/react": "^6.0.0",
    "@floating-ui/react": "^0.27.19",
    "@hookform/resolvers": "^5.4.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-table": "^8.21.3",
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.3",
    "chroma-js": "^3.2.0",
    "cva": "1.0.0-beta.4",
    "date-fns": "^4.4.0",
    "motion": "^12.40.0",
    "pagefind": "^1.5.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.13"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@significa/biome-config": "0.2.0",
    "@significa/tsconfig": "0.1.0",
    "knip": "^6.18.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "6.0.3"
  }
}
