---
import { readFile } from "fs/promises";
import path from "path";
import CodeBlock from "./code-block.astro";
import { Code } from "astro:components";
import type { CodeLanguage } from "astro";
import type { HTMLAttributes } from "astro/types";
import { themes } from "@/lib/shiki";

type Props = HTMLAttributes<"div"> & {
  file: string;
  collapsible?: boolean;
};

const { file, ...props } = Astro.props;

const content = await readFile(path.join(process.cwd(), file), "utf-8");
const extension = path.extname(file).slice(1);
---

<CodeBlock {...props}>
  <Code slot="pre" code={content} lang={extension as CodeLanguage} themes={themes} />
</CodeBlock>
