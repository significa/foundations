---
import { getEntry } from "astro:content";
import { ArrowSquareOutIcon, DesktopIcon, DeviceMobileIcon, DeviceTabletIcon } from "@phosphor-icons/react";
import SourceCode from "@/components/source-code.astro";
import { Button, buttonStyle, IconButton } from "@/foundations/ui/button/button";
import { cn } from "@/lib/utils/classnames";
import ComponentPreview from "./component-preview.astro";

type Props = {
  slug: string;
};

const { slug } = Astro.props;

const entry = await getEntry("previews", slug);

if (!entry) {
  throw new Error(`No preview found for slug: ${slug}`);
}

const previewPath = `/preview/${entry.id}`;

const { layout, mode, size } = entry.data.meta || {};
const isBlock = size === "block";
const showViewports = isBlock && mode === "iframe";

const viewports = [
  { id: "full", label: "Desktop", width: "100%", Icon: DesktopIcon },
  { id: "tablet", label: "Tablet", width: "768px", Icon: DeviceTabletIcon },
  { id: "mobile", label: "Mobile", width: "390px", Icon: DeviceMobileIcon },
];
---

<div
  class={cn("group/preview relative my-4", isBlock ? "h-150" : "h-85 md:h-100")}
  data-id="preview"
  data-view="preview"
  data-escape-markdown
>
  {
    showViewports && (
      <div class="absolute inset-x-0 top-0 z-20 flex items-center justify-center gap-1 p-3 group-data-[view=source]/preview:hidden">
        {viewports.map(({ id, label, width, Icon }) => (
          <IconButton
            size="sm"
            variant="ghost"
            aria-label={label}
            data-id="viewport-toggle"
            data-width={width}
            data-active={id === "full" ? "true" : undefined}
            className="text-foreground-secondary data-[active=true]:bg-background-secondary data-[active=true]:text-foreground"
          >
            <Icon />
          </IconButton>
        ))}
      </div>
    )
  }

  <div
    class={cn(
      "size-full overflow-hidden rounded-lg border group-data-[view=source]/preview:hidden",
      isBlock && "bg-background-secondary flex justify-center",
      showViewports && "pt-13"
    )}
  >
    <div
      data-id="viewport-frame"
      class={cn("ease-emphasized-decelerate size-full transition-[max-width] duration-300", isBlock && "bg-background")}
    >
      {
        mode === "iframe" ? (
          <iframe src={previewPath} class="size-full" title={`${entry.id} preview`} />
        ) : (
          <ComponentPreview file={entry.data.file} layout={layout} />
        )
      }
    </div>
  </div>

  <SourceCode file={entry.data.file} class="h-full group-data-[view=preview]/preview:hidden" />

  <div class="absolute right-0 bottom-0 z-20 flex items-center gap-2 p-3">
    <Button
      size="sm"
      variant="outline"
      data-id="preview-toggle"
      className="after:content-['source'] group-data-[view=source]/preview:after:content-['preview']"
    >
      View
    </Button>
    <a
      href={previewPath}
      target="_blank"
      class={buttonStyle({
        size: "sm",
        variant: "outline",
        square: true,
        className: "no-underline cursor-pointer",
      })}
    >
      <ArrowSquareOutIcon />
    </a>
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const toggles = [...document.querySelectorAll("[data-id=preview-toggle]")];

    for (const toggle of toggles) {
      toggle?.addEventListener("click", () => {
        const container = toggle.closest("[data-id=preview]");
        if (!container) return;

        const currentView = container.getAttribute("data-view");
        const newView = currentView === "preview" ? "source" : "preview";

        container.setAttribute("data-view", newView);
      });
    }

    // Responsive viewport toggles for block previews.
    const viewportToggles = [...document.querySelectorAll("[data-id=viewport-toggle]")];

    for (const toggle of viewportToggles) {
      toggle.addEventListener("click", () => {
        const container = toggle.closest("[data-id=preview]");
        const frame = container?.querySelector<HTMLElement>("[data-id=viewport-frame]");
        if (!container || !frame) return;

        frame.style.maxWidth = toggle.getAttribute("data-width") || "100%";

        for (const sibling of container.querySelectorAll("[data-id=viewport-toggle]")) {
          sibling.removeAttribute("data-active");
        }
        toggle.setAttribute("data-active", "true");
      });
    }
  });
</script>
