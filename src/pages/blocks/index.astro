---
import { getCollection } from "astro:content";
import { ArrowRightIcon } from "@phosphor-icons/react";
import PageLayout from "@/layouts/page.astro";
import Shell from "@/layouts/shell.astro";

const pages = await getCollection("pages");

const blocks = pages
  .filter((page) => page.data.folder === "Blocks")
  .sort((a, b) => (a.data.meta?.order ?? 0) - (b.data.meta?.order ?? 0));
---

<Shell
  meta={{
    title: "Blocks",
    description: "Full, ready-to-paste sections assembled from Foundations primitives.",
  }}
>
  <PageLayout wide data-pagefind-meta="folder:Blocks">
    <section class="mb-10">
      <h1 class="font-heading text-3xl font-bold tracking-tight">Blocks</h1>
      <p class="text-foreground-secondary mt-2 max-w-2xl text-pretty">
        Full sections — dashboards, auth, app shells — assembled from Foundations primitives. Copy a block whole, then swap the
        content for your own. Each block lists every primitive it pulls in.
      </p>
    </section>

    <div class="grid gap-6 sm:grid-cols-2">
      {
        blocks.map((block) => (
          <a
            href={`/${block.id}`}
            class="group/card border-border hover:bg-foreground/2 block overflow-hidden rounded-2xl border transition"
          >
            <div class="bg-background-secondary relative h-64 overflow-hidden border-b">
              {block.data.preview && (
                <iframe
                  src={`/preview/${block.data.preview.id}`}
                  class="pointer-events-none absolute inset-0 size-full"
                  title={`${block.data.title} preview`}
                  loading="lazy"
                />
              )}
            </div>
            <div class="flex items-start justify-between gap-4 p-4">
              <div>
                <h2 class="font-medium">{block.data.title}</h2>
                <p class="text-foreground-secondary mt-1 text-sm text-pretty">{block.data.description}</p>
              </div>
              <ArrowRightIcon className="text-foreground-secondary mt-1 shrink-0 transition group-hover/card:translate-x-0.5" />
            </div>
          </a>
        ))
      }
    </div>
  </PageLayout>
</Shell>
